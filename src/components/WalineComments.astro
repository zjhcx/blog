---
import { CommentConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import WalineClient from "./WalineComments.svelte";

interface Props {
	path: string;
}

const { path } = Astro.props;
const serverURL = CommentConfig.serverURL.trim();
---

{
	CommentConfig.enable && (
		<section class="card-base mb-4 overflow-hidden">
			<div class="px-6 md:px-9 pt-6 pb-3">
				<h2 class="text-90 text-2xl font-bold" data-i18n-key={I18nKey.comments}>
					{i18n(I18nKey.comments)}
				</h2>
			</div>
			<div class="px-6 md:px-9 pb-6">
				{serverURL ? (
					<WalineClient client:load serverURL={serverURL} path={path} />
				) : (
					<p class="text-50" data-i18n-key={I18nKey.commentsNotConfigured}>
						{i18n(I18nKey.commentsNotConfigured)}
					</p>
				)}
			</div>
		</section>
	)
}

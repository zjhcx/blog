---
import { Icon } from "astro-icon/components";
import authIconSvg from "@/assets/svg/auth-icon.svg?raw";
import { FollowsConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { type FollowItem, getFollowUrl } from "@/utils/follows";
import "../styles/follows.css";

interface Props {
	items: FollowItem[];
	errorMessage?: string;
}

const { items: follows, errorMessage = "" } = Astro.props;

const getVerifyText = (item: FollowItem) =>
	item.official_verify?.desc || i18n(I18nKey.followsOfficial);
const getVerifyType = (item: FollowItem) => item.official_verify?.type;
const hasOfficialVerify = (item: FollowItem) =>
	getVerifyType(item) === 0 || getVerifyType(item) === 1;
const getVerifyColor = (item: FollowItem) =>
	getVerifyType(item) === 0 ? "#FFCC00" : "#40C5F1";
const getVipType = (item: FollowItem) =>
	item.vip?.type ?? item.vip?.vipType ?? 0;
const getVipLabelPath = (item: FollowItem) => item.vip?.label?.path || "";
const hasVipLabel = (item: FollowItem) =>
	getVipType(item) !== 0 && Boolean(getVipLabelPath(item));
---

<div class="follows-page follows-page-root">
	<section class="follows-page-hero card-base">
		<h1 class="follows-page-title text-90" data-i18n-key={I18nKey.follows}>
			{i18n(I18nKey.follows)}
		</h1>
		<p class="follows-page-description text-50" data-i18n-key={I18nKey.followsDescription}>
			{i18n(I18nKey.followsDescription)}
		</p>
	</section>

	{
		!FollowsConfig.enable && (
			<section class="follows-state card-base text-50" data-i18n-key={I18nKey.followsDisabled}>
				{i18n(I18nKey.followsDisabled)}
			</section>
		)
	}

	{
		FollowsConfig.enable && errorMessage && (
			<section class="follows-state card-base text-50">
				<span data-i18n-key={I18nKey.followsLoadFailed}>
					{i18n(I18nKey.followsLoadFailed)}
				</span>
				{errorMessage}
			</section>
		)
	}

	{
		FollowsConfig.enable && !errorMessage && follows.length === 0 && (
			<section class="follows-state card-base text-50" data-i18n-key={I18nKey.followsEmpty}>
				{i18n(I18nKey.followsEmpty)}
			</section>
		)
	}

	{
		FollowsConfig.enable && !errorMessage && follows.length > 0 && (
			<section class="follows-list">
				{follows.map((item, index) => (
					<a
						class="follows-card card-base text-90"
						href={getFollowUrl(item)}
						target="_blank"
						rel="noopener noreferrer"
						style={`animation-delay: calc(var(--content-delay) + ${index * 50}ms)`}
					>
						<div class="follows-avatar-wrap">
							<img class="follows-avatar" src={item.face} alt={item.uname} loading="lazy" referrerpolicy="no-referrer" />
							{hasOfficialVerify(item) && (
								<span
									class="follows-auth-icon"
									style={`--auth-color: ${getVerifyColor(item)}`}
									title={getVerifyText(item)}
									aria-label={getVerifyText(item)}
									role="img"
									set:html={authIconSvg}
								/>
							)}
						</div>
						<div class="follows-content">
							<div class="follows-header">
								<div class="follows-name-line">
									<h2 class="follows-name" style={item.vip?.nickname_color ? `color: ${item.vip.nickname_color}` : undefined}>
										{item.uname}
									</h2>
									{hasVipLabel(item) && (
										<img
											class="follows-vip-label"
											src={getVipLabelPath(item)}
											alt={item.vip?.label?.text || i18n(I18nKey.followsVip)}
											loading="lazy"
											referrerpolicy="no-referrer"
										/>
									)}
								</div>
								<Icon
									class="follows-enter"
									name="material-symbols:chevron-right-rounded"
								/>
							</div>
							<p class="follows-sign text-50">{item.sign || "..."}</p>
						</div>
					</a>
				))}
			</section>
		)
	}
</div>

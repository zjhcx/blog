---
import Pagination from "@components/control/Pagination.astro";
import FavsComponent from "@components/Favs.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import type { GetStaticPaths } from "astro";
import { FavoritesConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { getFavoriteFolders } from "@/utils/favorites";

export const getStaticPaths = (async ({ paginate }) => {
	const { items, errorMessage } = await getFavoriteFolders();
	return paginate(items, {
		pageSize: Math.max(FavoritesConfig.foldersPageSize, 1),
		params: { page: undefined },
		props: { errorMessage },
	});
}) satisfies GetStaticPaths;

const { page, errorMessage } = Astro.props;
const showPagination =
	!FavoritesConfig.hidePaginationWhenSinglePage || page.lastPage > 1;
---

<MainGridLayout title={i18n(I18nKey.favs)} description={i18n(I18nKey.favsDescription)}>
	<FavsComponent items={page.data} errorMessage={errorMessage} />
	{
		showPagination && (
			<Pagination
				class="mx-auto mt-6 onload-animation"
				page={page}
				basePath="/favs/"
				style={`animation-delay: calc(var(--content-delay) + ${page.data.length * 50}ms)`}
			/>
		)
	}
</MainGridLayout>

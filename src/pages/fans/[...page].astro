---
import Pagination from "@components/control/Pagination.astro";
import FansComponent from "@components/Fans.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import type { GetStaticPaths } from "astro";
import { FansConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { getFanItems } from "@/utils/fans";

export const getStaticPaths = (async ({ paginate }) => {
	const { items, errorMessage } = await getFanItems();
	return paginate(items, {
		pageSize: Math.max(FansConfig.pageSize, 1),
		params: { page: undefined },
		props: { errorMessage },
	});
}) satisfies GetStaticPaths;

const { page, errorMessage } = Astro.props;
const showPagination =
	!FansConfig.hidePaginationWhenSinglePage || page.lastPage > 1;
---

<MainGridLayout title={i18n(I18nKey.fans)} description={i18n(I18nKey.fansDescription)}>
	<FansComponent items={page.data} errorMessage={errorMessage} />
	{
		showPagination && (
			<Pagination
				class="mx-auto mt-6 onload-animation"
				page={page}
				basePath="/fans/"
				style={`animation-delay: calc(var(--content-delay) + ${page.data.length * 50}ms)`}
			/>
		)
	}
</MainGridLayout>

---
import MainGridLayout from '../layouts/MainGridLayout.astro'

const friends = [
  {
    name: 'GitHub',
    url: 'https://github.com',
    avatar: 'https://github.com/github.png',
    desc: 'GitHub 是一个面向开源及私有软件项目的托管平台',
  },
  {
    name: 'OpenAI',
    url: 'https://openai.com',
    avatar: 'https://github.com/openai.png',
    desc: 'ChatGPT 是 OpenAI 开发的一个基于 GPT-4 架构的语言模型',
  },
  {
    name: '哔哩哔哩',
    url: 'https://space.bilibili.com',
    avatar: 'https://www.bilibili.com/favicon.ico',
    desc: '哔哩哔哩是国内知名的视频弹幕网站',
  },
  {
    name: 'X',
    url: 'https://x.com',
    avatar: 'https://x.com/favicon.ico',
    desc: 'X 是一个社交媒体平台',
  },
  {
    name: 'Discord',
    url: 'https://discord.com',
    avatar: 'https://cdn.prod.website-files.com/6257adef93867e50d84d30e2/62fddf0fde45a8baedcc7ee5_847541504914fd33810e70a0ea73177e%20(2)-1.png',
    desc: 'Discord 是一个流行的聊天和社交平台',
  },
  {
    name: 'Cloudflare',
    url: 'https://cloudflare.com',
    avatar: 'https://cloudflare.com/favicon.ico',
    desc: '赛博活佛',
  },
]
---

<MainGridLayout title="友情链接" description="朋友们的博客">
  <div class="links-page">
    <section class="hero-card">
      <h1>友情链接</h1>
    </section>

    <section class="links-grid">
      {
        friends.map(friend => (
          <a class="friend-card" href={friend.url} target="_blank" rel="noopener noreferrer">
            <div class="avatar-wrap">
              <img src={friend.avatar} alt={friend.name} loading="lazy" />
            </div>

            <div class="friend-info">
              <h2>{friend.name}</h2>
              <p>{friend.desc}</p>
            </div>
          </a>
        ))
      }
    </section>
  </div>
</MainGridLayout>

<style>
.links-page {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.hero-card {
  padding: 1.6rem;
  border-radius: 1.5rem;
  background: var(--card-bg);
  box-shadow: var(--shadow);
  border: 1px solid var(--line-divider);
}

.hero-card h1 {
  margin: 0 0 0.5rem;
  font-size: 2rem;
  font-weight: 700;
}

.hero-card p,
.apply-card p {
  margin: 0;
  color: var(--text-50);
}

.links-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1rem;
}

.friend-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 1rem;

  min-height: 96px;
  padding: 1rem;

  border-radius: 1.4rem;
  background: var(--card-bg);
  border: 1px solid var(--line-divider);
  box-shadow: var(--shadow);

  overflow: hidden;
  text-decoration: none;
  color: var(--text-90);

  transition:
    transform 0.25s ease,
    box-shadow 0.25s ease,
    border-color 0.25s ease;
}

.friend-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top left, rgba(var(--primary), 0.18), transparent 45%),
    linear-gradient(135deg, rgba(var(--primary), 0.08), transparent 55%);
  opacity: 0;
  transition: opacity 0.25s ease;
}

.friend-card:hover {
  transform: translateY(-4px);
  border-color: rgba(var(--primary), 0.45);
  box-shadow: 0 14px 35px rgba(0, 0, 0, 0.12);
}

.friend-card:hover::before {
  opacity: 1;
}

.avatar-wrap {
  position: relative;
  z-index: 1;

  flex: 0 0 auto;
  width: 58px;
  height: 58px;
  padding: 3px;

  border-radius: 50%;
  background: linear-gradient(135deg, rgba(var(--primary), 0.9), rgba(var(--primary), 0.25));
}

.avatar-wrap img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--card-bg);
  object-fit: cover;
}

.friend-info {
  position: relative;
  z-index: 1;
  min-width: 0;
}

.friend-info h2 {
  margin: 0 0 0.35rem;
  font-size: 1.05rem;
  font-weight: 700;

  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.friend-info p {
  margin: 0;
  font-size: 0.9rem;
  line-height: 1.45;
  color: var(--text-50);

  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.apply-card h2 {
  margin: 0 0 0.5rem;
  font-size: 1.35rem;
}

.apply-card pre {
  margin: 1rem 0 0;
  padding: 1rem;
  border-radius: 1rem;

  overflow-x: auto;
  font-size: 0.9rem;
  line-height: 1.6;

  background: rgba(var(--primary), 0.08);
  color: var(--text-90);
}

@media (max-width: 640px) {
  .hero-card,
  .apply-card {
    padding: 1.25rem;
  }

  .links-grid {
    grid-template-columns: 1fr;
  }

  .friend-card {
    min-height: 88px;
  }

  .avatar-wrap {
    width: 52px;
    height: 52px;
  }
}
</style>